source 'https://rubygems.org'

group :jekyll_plugins do
  gem 'jekyll'
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'webrick', '~> 1.8'
end

gem 'github-pages'
gem 'connection_pool', '2.5.0'

# Windows: Ruby ships no zoneinfo DB; bundle timezone data for local builds only
gem 'tzinfo-data', platforms: [:mingw, :mswin, :x64_mingw, :jruby]
